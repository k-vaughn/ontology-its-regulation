     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:i72="https://w3id.org/citydata/21972/v1/"
     xmlns:prov="http://www.w3.org/ns/prov#"
     xmlns:org="http://www.w3.org/ns/org#"
     xmlns:time="http://www.w3.org/2006/time#"
     xmlns:cdm1="https://w3id.org/citydata/part1/v1/"
     xmlns:cdm2="https://w3id.org/citydata/part2/v1/"
     xmlns:cdm3="https://w3id.org/citydata/part3/v1/"
     xmlns:its-core="https://w3id.org/itsdata/core/v1/"
     xmlns:its-time="https://w3id.org/itsdata/time/v1/"
     xmlns:its-location="https://w3id.org/itsdata/location/v1/">
    <owl:Ontology rdf:about="https://w3id.org/itsdata/regulation/v1/">
    	<!-- Identity -->
    	<dcterms:title>Traffic Regulation Ontology</dcterms:title>
    	<skos:definition>This ontology defines concepts related to traffic regulations.</skos:definition>
    	<vann:preferredNamespaceUri>https://w3id.org/itsdata/regulation/v1/</vann:preferredNamespaceUri>
    	<vann:preferredNamespacePrefix>its-regulation</vann:preferredNamespacePrefix>
        <cdm1:mainModule>true</cdm1:mainModule>
    		
    	<!-- Provenance -->
    	<dcterms:creator>Kenneth Vaughn</dcterms:creator>
        <dcterms:created>Draft</dcterms:created>
        <!-- Prior release -->
        <owl:priorVersion rdf:resource="https://w3id.org/itsdata/regulation/v1/r0.1"/>
        <!-- This release -->
		<dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-03</dcterms:modified>
        <owl:versionInfo>0.0.2</owl:versionInfo>
        <owl:versionIRI rdf:resource="https://w3id.org/itsdata/regulation/v1/r0.2"/>

        <!-- License -->
        <dcterms:license>http://creativecommons.org/licenses/by/4.0/</dcterms:license>
        
        <!-- Imports -->
        <owl:imports rdf:resource="http://www.w3.org/2002/07/owl"/>
        <owl:imports rdf:resource="http://www.w3.org/2003/11/swrl"/>
        <owl:imports rdf:resource="http://www.w3.org/2003/11/swrlb"/>
        <owl:imports rdf:resource="http://www.w3.org/2006/time"/>
        <owl:imports rdf:resource="https://w3id.org/citydata/part1/"/>
        <owl:imports rdf:resource="https://w3id.org/itsdata/core/"/>
        <owl:imports rdf:resource="https://w3id.org/itsdata/location/"/>
        <owl:imports rdf:resource="https://w3id.org/itsdata/time/"/>
        <owl:imports rdf:resource="https://www.opengis.net/ont/geosparql"/>
    </owl:Ontology>
    
    <skos:Collection rdf:about="https://w3id.org/itsdata/regulation/TrafficRegulationOrderPattern">
        <skos:prefLabel xml:lang="en">Traffic Regulation Pattern</skos:prefLabel>
        <skos:member rdf:resource="https://w3id.org/itsdata/regulation/"/>
        <skos:member rdf:resource="https://w3id.org/itsdata/regulation/"/>
        <skos:member rdf:resource="https://w3id.org/itsdata/regulation/"/>
        <skos:member rdf:resource="https://w3id.org/itsdata/regulation/"/>
        <skos:member rdf:resource="https://w3id.org/itsdata/regulation/"/>
        <skos:member rdf:resource="https://w3id.org/itsdata/regulation/"/>
    </skos:Collection>    

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- https://w3id.org/itsdata/regulation/TroObjectProperty -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/regulation/RegulationObjectProperty">
    		<skos:definition>An object property to organize all object properties defined in the Traffic Regulation Ontology.</skos:definition>
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/core/ITSObjectProperty"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/itsdata/regulation/implementedLocation -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/regulation/implementedLocation">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/regulation/RegulationObjectProperty"/>
        <skos:definition>The location where the instance of the traffic regulation order is implemented.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/itsdata/regulation/implementedValidity -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/regulation/implementedValidity">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/regulation/RegulationObjectProperty"/>
        <skos:definition>The validity period during which the instance of the traffic regulation order is implemented.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/itsdata/regulation/issuingAuthority -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/regulation/issuingAuthority">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/regulation/RegulationObjectProperty"/>
        <dcterms:description>The entity that issued the instance of the traffic regulation order</dcterms:description>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/itsdata/regulation/legalBasis -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/regulation/legalBasis">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/regulation/RegulationObjectProperty"/>
        <dcterms:description>formal authority within the law (e.g., statute, ordinance, administrative rule, constitutional provision) that empowers an entity to create, adopt, or enforce a regulation</dcterms:description>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/itsdata/regulation/reasonCode -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/regulation/reasonCode">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/regulation/RegulationObjectProperty"/>
        <dcterms:description>A reason justifying the existence of the instance of the traffic regulation order</dcterms:description>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/itsdata/regulation/status -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/regulation/status">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/regulation/RegulationObjectProperty"/>
        <dcterms:description>The current lifecycle status of the instance of the containing class</dcterms:description>
        <skos:example>The current lifecycle status of the traffic regulation order</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/itsdata/regulation/trafficRegulations -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/regulation/trafficRegulations">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/regulation/RegulationObjectProperty"/>
        <skos:definition>The set of traffic regulations enacted by the traffic regulation order.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/itsdata/regulation/validityByOrder -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/regulation/validityByOrder">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/regulation/RegulationObjectProperty"/>
        <skos:definition>The validity period as defined by the traffic regulation order.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    
    <!-- https://w3id.org/itsdata/regulation/TroDataProperty -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/itsdata/regulation/TroDataProperty">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/core/ITSDataProperty"/>
        <skos:definition>A data property to organize all data properties defined in the Traffic Regulation Ontology.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/itsdata/time/approvalDate -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/itsdata/time/approvalDate">
        <skos:definition>The date on which the object was approved.</skos:definition>
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/time/TimeDataProperty"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/itsdata/core/version -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/itsdata/core/version">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/core/ITSDataProperty"/>
        <skos:definition>The version of the object.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
