// Diagram for Condition
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		RegulationThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">RegulationThing</TD></TR></TABLE>> URL="../RegulationThing" margin=0]
	}
	Condition [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Condition</TD></TR><TR><TD ALIGN="LEFT">cdm1:negate : xsd:boolean</TD></TR></TABLE>> URL="../Condition" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		xsd_boolean [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">xsd:boolean</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/xsd/latest/boolean" margin=0]
	}
	Condition -> RegulationThing [arrowhead=onormal style=solid]
	Condition -> Invis [style=invis]
	Invis -> xsd_boolean [style=invis]
	xsd_boolean [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">xsd:boolean</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/xsd/latest/boolean" margin=0]
	Condition -> xsd_boolean [label=isActive arrowhead=normal style=solid]
}
