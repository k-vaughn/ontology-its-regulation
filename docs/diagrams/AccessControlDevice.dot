// Diagram for AccessControlDevice
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		"its-location_PointFeature" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-location:PointFeature</TD></TR></TABLE>> URL="https://w3id.org/itsdata/location/v1/PointFeature" margin=0]
		TrafficControlDevice [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TrafficControlDevice</TD></TR></TABLE>> URL="../TrafficControlDevice" margin=0]
	}
	AccessControlDevice [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">AccessControlDevice</TD></TR></TABLE>> URL="../AccessControlDevice" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		AccessControlTypeCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">AccessControlTypeCode</TD></TR></TABLE>> URL="../AccessControlTypeCode" margin=0]
	}
	AccessControlDevice -> "its-location_PointFeature" [arrowhead=onormal style=solid]
	AccessControlDevice -> TrafficControlDevice [arrowhead=onormal style=solid]
	AccessControlDevice -> Invis [style=invis]
	Invis -> AccessControlTypeCode [style=invis]
	AccessControlTypeCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">AccessControlTypeCode</TD></TR></TABLE>> URL="../AccessControlTypeCode" margin=0]
	AccessControlDevice -> AccessControlTypeCode [label=accessControlType arrowhead=normal style=solid]
}
