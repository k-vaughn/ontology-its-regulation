// Diagram for ChannelizationDevice
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		"its-location_LinearFeature" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-location:LinearFeature</TD></TR></TABLE>> URL="https://w3id.org/itsdata/location/v1/LinearFeature" margin=0]
		TrafficControlDevice [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TrafficControlDevice</TD></TR></TABLE>> URL="../TrafficControlDevice" margin=0]
	}
	ChannelizationDevice [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ChannelizationDevice</TD></TR></TABLE>> URL="../ChannelizationDevice" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		ChannelizationTypeCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ChannelizationTypeCode</TD></TR></TABLE>> URL="../ChannelizationTypeCode" margin=0]
	}
	ChannelizationDevice -> "its-location_LinearFeature" [arrowhead=onormal style=solid]
	ChannelizationDevice -> TrafficControlDevice [arrowhead=onormal style=solid]
	ChannelizationDevice -> Invis [style=invis]
	Invis -> ChannelizationTypeCode [style=invis]
	ChannelizationTypeCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ChannelizationTypeCode</TD></TR></TABLE>> URL="../ChannelizationTypeCode" margin=0]
	ChannelizationDevice -> ChannelizationTypeCode [label=channelizationType arrowhead=normal style=solid]
}
