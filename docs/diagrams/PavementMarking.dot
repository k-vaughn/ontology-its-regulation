// Diagram for PavementMarking
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		"its-location_LinearFeature" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-location:LinearFeature</TD></TR></TABLE>> URL="https://w3id.org/itsdata/location/v1/LinearFeature" margin=0]
		TrafficControlDevice [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TrafficControlDevice</TD></TR></TABLE>> URL="../TrafficControlDevice" margin=0]
	}
	PavementMarking [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PavementMarking</TD></TR></TABLE>> URL="../PavementMarking" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		PavementMarkingTypeCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PavementMarkingTypeCode</TD></TR></TABLE>> URL="../PavementMarkingTypeCode" margin=0]
	}
	PavementMarking -> "its-location_LinearFeature" [arrowhead=onormal style=solid]
	PavementMarking -> TrafficControlDevice [arrowhead=onormal style=solid]
	PavementMarking -> Invis [style=invis]
	Invis -> PavementMarkingTypeCode [style=invis]
	PavementMarkingTypeCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PavementMarkingTypeCode</TD></TR></TABLE>> URL="../PavementMarkingTypeCode" margin=0]
	PavementMarking -> PavementMarkingTypeCode [label=pavementMarkingType arrowhead=normal style=solid]
}
