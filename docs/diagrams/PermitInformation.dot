// Diagram for PermitInformation
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		RegulationThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">RegulationThing</TD></TR></TABLE>> URL="../RegulationThing" margin=0]
	}
	PermitInformation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PermitInformation</TD></TR><TR><TD ALIGN="LEFT">contactInformation : cdm2:ContactInformation</TD></TR></TABLE>> URL="../PermitInformation" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		owl_Thing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">owl:Thing</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/owl/latest/Thing" margin=0]
		PermitFee [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PermitFee</TD></TR></TABLE>> URL="../PermitFee" margin=0]
		RegistrationMachine [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">RegistrationMachine</TD></TR></TABLE>> URL="../RegistrationMachine" margin=0]
	}
	PermitInformation -> RegulationThing [arrowhead=onormal style=solid]
	PermitInformation -> Invis [style=invis]
	Invis -> owl_Thing [style=invis]
	owl_Thing -> PermitFee [style=invis]
	PermitFee -> RegistrationMachine [style=invis]
	owl_Thing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">owl:Thing</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/owl/latest/Thing" margin=0]
	PermitInformation -> owl_Thing [label=displayType arrowhead=normal style=solid]
	PermitInformation -> owl_Thing [label=grantsPermission arrowhead=normal style=solid]
	PermitFee [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PermitFee</TD></TR></TABLE>> URL="../PermitFee" margin=0]
	PermitInformation -> PermitFee [label=hasAssociatedFee arrowhead=normal style=solid]
	RegistrationMachine [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">RegistrationMachine</TD></TR></TABLE>> URL="../RegistrationMachine" margin=0]
	PermitInformation -> RegistrationMachine [label=hasRegistrationMachine arrowhead=normal style=solid]
	PermitInformation -> owl_Thing [label=howToObtainPermit arrowhead=normal style=solid]
	PermitInformation -> owl_Thing [label=isLocationSpecific arrowhead=normal style=solid]
	PermitInformation -> owl_Thing [label=maximumDurationOfPermit arrowhead=normal style=solid]
	PermitInformation -> owl_Thing [label=minimumTimeToNextEntry arrowhead=normal style=solid]
	PermitInformation -> owl_Thing [label=permittedEntityType arrowhead=normal style=solid]
	PermitInformation -> owl_Thing [label=urlForInformation arrowhead=normal style=solid]
	PermitInformation -> owl_Thing [label=urlForApplication arrowhead=normal style=solid]
}
