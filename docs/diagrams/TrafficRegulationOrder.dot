// Diagram for TrafficRegulationOrder
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		RegulationThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">RegulationThing</TD></TR></TABLE>> URL="../RegulationThing" margin=0]
	}
	TrafficRegulationOrder [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TrafficRegulationOrder</TD></TR><TR><TD ALIGN="LEFT">cdm1:hasIdentifier : xsd:string</TD></TR></TABLE>> URL="../TrafficRegulationOrder" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		ImplementationStatusCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ImplementationStatusCode</TD></TR></TABLE>> URL="../ImplementationStatusCode" margin=0]
		"its-location_LocationReference" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-location:LocationReference</TD></TR></TABLE>> URL="https://w3id.org/itsdata/location/v1/LocationReference" margin=0]
		"its-time_Validity" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-time:Validity</TD></TR></TABLE>> URL="https://w3id.org/itsdata/time/v1/Validity" margin=0]
		LegalBasis [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">LegalBasis</TD></TR></TABLE>> URL="../LegalBasis" margin=0]
		ReasonCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ReasonCode</TD></TR></TABLE>> URL="../ReasonCode" margin=0]
		RuleMakerRole [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">RuleMakerRole</TD></TR></TABLE>> URL="../RuleMakerRole" margin=0]
		TrafficRegulation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TrafficRegulation</TD></TR></TABLE>> URL="../TrafficRegulation" margin=0]
	}
	TrafficRegulationOrder -> RegulationThing [arrowhead=onormal style=solid]
	TrafficRegulationOrder -> Invis [style=invis]
	Invis -> ImplementationStatusCode [style=invis]
	ImplementationStatusCode -> "its-location_LocationReference" [style=invis]
	"its-location_LocationReference" -> "its-time_Validity" [style=invis]
	"its-time_Validity" -> LegalBasis [style=invis]
	LegalBasis -> ReasonCode [style=invis]
	ReasonCode -> RuleMakerRole [style=invis]
	RuleMakerRole -> TrafficRegulation [style=invis]
	RuleMakerRole [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">RuleMakerRole</TD></TR></TABLE>> URL="../RuleMakerRole" margin=0]
	TrafficRegulationOrder -> RuleMakerRole [label=issuingAuthority arrowhead=normal style=solid]
	ReasonCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ReasonCode</TD></TR></TABLE>> URL="../ReasonCode" margin=0]
	TrafficRegulationOrder -> ReasonCode [label=reasonCode arrowhead=normal style=solid]
	ImplementationStatusCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ImplementationStatusCode</TD></TR></TABLE>> URL="../ImplementationStatusCode" margin=0]
	TrafficRegulationOrder -> ImplementationStatusCode [label=implementationStatus arrowhead=normal style=solid]
	LegalBasis [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">LegalBasis</TD></TR></TABLE>> URL="../LegalBasis" margin=0]
	TrafficRegulationOrder -> LegalBasis [label=legalBasis arrowhead=normal style=solid]
	"its-location_LocationReference" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-location:LocationReference</TD></TR></TABLE>> URL="https://w3id.org/itsdata/location/v1/LocationReference" margin=0]
	TrafficRegulationOrder -> "its-location_LocationReference" [label=implementedLocation arrowhead=normal style=solid]
	TrafficRegulationOrder -> "its-location_LocationReference" [label=locationByOrder arrowhead=normal style=solid]
	"its-time_Validity" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-time:Validity</TD></TR></TABLE>> URL="https://w3id.org/itsdata/time/v1/Validity" margin=0]
	TrafficRegulationOrder -> "its-time_Validity" [label=implementedValidity arrowhead=normal style=solid]
	TrafficRegulationOrder -> "its-time_Validity" [label=validityByOrder arrowhead=normal style=solid]
	TrafficRegulation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TrafficRegulation</TD></TR></TABLE>> URL="../TrafficRegulation" margin=0]
	TrafficRegulationOrder -> TrafficRegulation [label=memberTrafficRegulation arrowhead=normal style=solid]
}
