// Diagram for SimpleSign
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		InternationalSign [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">InternationalSign</TD></TR></TABLE>> URL="../InternationalSign" margin=0]
	}
	SimpleSign [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">SimpleSign</TD></TR></TABLE>> URL="../SimpleSign" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		Condition [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Condition</TD></TR></TABLE>> URL="../Condition" margin=0]
		TypeOfRegulation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TypeOfRegulation</TD></TR></TABLE>> URL="../TypeOfRegulation" margin=0]
	}
	SimpleSign -> InternationalSign [arrowhead=onormal style=solid]
	SimpleSign -> Invis [style=invis]
	Invis -> Condition [style=invis]
	Condition -> TypeOfRegulation [style=invis]
	TypeOfRegulation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TypeOfRegulation</TD></TR></TABLE>> URL="../TypeOfRegulation" margin=0]
	SimpleSign -> TypeOfRegulation [label=hasDetails arrowhead=normal style=solid]
	Condition [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Condition</TD></TR></TABLE>> URL="../Condition" margin=0]
	SimpleSign -> Condition [label=hasCondition arrowhead=normal style=solid]
}
