// Diagram for InternationalSign
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		"its-location_PointFeature" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-location:PointFeature</TD></TR></TABLE>> URL="https://w3id.org/itsdata/location/v1/PointFeature" margin=0]
		TrafficControlDevice [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TrafficControlDevice</TD></TR></TABLE>> URL="../TrafficControlDevice" margin=0]
	}
	InternationalSign [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">InternationalSign</TD></TR></TABLE>> URL="../InternationalSign" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		owl_Thing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">owl:Thing</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/owl/latest/Thing" margin=0]
	}
	InternationalSign -> "its-location_PointFeature" [arrowhead=onormal style=solid]
	InternationalSign -> TrafficControlDevice [arrowhead=onormal style=solid]
	InternationalSign -> Invis [style=invis]
	Invis -> owl_Thing [style=invis]
	owl_Thing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">owl:Thing</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/owl/latest/Thing" margin=0]
	InternationalSign -> owl_Thing [label=pictogram arrowhead=normal style=solid]
	InternationalSign -> owl_Thing [label=nationalSignId arrowhead=normal style=solid]
}
