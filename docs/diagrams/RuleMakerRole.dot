// Diagram for RuleMakerRole
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		"its-agent_Role" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-agent:Role</TD></TR></TABLE>> URL="https://w3id.org/itsdata/agent/v1/Role" margin=0]
		RegulationThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">RegulationThing</TD></TR></TABLE>> URL="../RegulationThing" margin=0]
	}
	RuleMakerRole [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">RuleMakerRole</TD></TR><TR><TD ALIGN="LEFT">its-core:jurisdiction</TD></TR></TABLE>> URL="../RuleMakerRole" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		RegulatoryScopeCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">RegulatoryScopeCode</TD></TR></TABLE>> URL="../RegulatoryScopeCode" margin=0]
		TrafficRegulationOrder [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TrafficRegulationOrder</TD></TR></TABLE>> URL="../TrafficRegulationOrder" margin=0]
	}
	RuleMakerRole -> "its-agent_Role" [arrowhead=onormal style=solid]
	RuleMakerRole -> RegulationThing [arrowhead=onormal style=solid]
	RuleMakerRole -> Invis [style=invis]
	Invis -> RegulatoryScopeCode [style=invis]
	RegulatoryScopeCode -> TrafficRegulationOrder [style=invis]
	TrafficRegulationOrder [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TrafficRegulationOrder</TD></TR></TABLE>> URL="../TrafficRegulationOrder" margin=0]
	RuleMakerRole -> TrafficRegulationOrder [label=issuedTro arrowhead=normal style=solid]
	RegulatoryScopeCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">RegulatoryScopeCode</TD></TR></TABLE>> URL="../RegulatoryScopeCode" margin=0]
	RuleMakerRole -> RegulatoryScopeCode [label=regulatoryScope arrowhead=normal style=solid]
}
