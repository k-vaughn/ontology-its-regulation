// Diagram for TrafficRegulation
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		RegulationThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">RegulationThing</TD></TR></TABLE>> URL="../RegulationThing" margin=0]
	}
	TrafficRegulation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TrafficRegulation</TD></TR><TR><TD ALIGN="LEFT">its-core:activationStatus</TD></TR></TABLE>> URL="../TrafficRegulation" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		Condition [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Condition</TD></TR></TABLE>> URL="../Condition" margin=0]
		PermitInformation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PermitInformation</TD></TR></TABLE>> URL="../PermitInformation" margin=0]
		TrafficControlDevice [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TrafficControlDevice</TD></TR></TABLE>> URL="../TrafficControlDevice" margin=0]
		TypeOfRegulation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TypeOfRegulation</TD></TR></TABLE>> URL="../TypeOfRegulation" margin=0]
	}
	TrafficRegulation -> RegulationThing [arrowhead=onormal style=solid]
	TrafficRegulation -> Invis [style=invis]
	Invis -> Condition [style=invis]
	Condition -> PermitInformation [style=invis]
	PermitInformation -> TrafficControlDevice [style=invis]
	TrafficControlDevice -> TypeOfRegulation [style=invis]
	TypeOfRegulation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TypeOfRegulation</TD></TR></TABLE>> URL="../TypeOfRegulation" margin=0]
	TrafficRegulation -> TypeOfRegulation [label=hasDetails arrowhead=normal style=solid]
	TrafficControlDevice [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TrafficControlDevice</TD></TR></TABLE>> URL="../TrafficControlDevice" margin=0]
	TrafficRegulation -> TrafficControlDevice [label=associatedTrafficControlDevice arrowhead=normal style=solid]
	Condition [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Condition</TD></TR></TABLE>> URL="../Condition" margin=0]
	TrafficRegulation -> Condition [label=hasCondition arrowhead=normal style=solid]
	PermitInformation [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PermitInformation</TD></TR></TABLE>> URL="../PermitInformation" margin=0]
	TrafficRegulation -> PermitInformation [label=permitInformation arrowhead=normal style=solid]
}
