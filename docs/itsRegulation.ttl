@prefix : <https://w3id.org/itsdata/regulation/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cdm1: <https://w3id.org/citydata/part1/> .
@prefix cdm2: <https://w3id.org/citydata/part2/> .
@prefix cdm3: <https://w3id.org/citydata/part3/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix terms: <http://purl.org/dc/terms/> .
@prefix its-core: <https://w3id.org/itsdata/core/> .
@prefix its-time: <https://w3id.org/itsdata/time/> .
@prefix its-location: <https://w3id.org/itsdata/location/> .
@base <https://w3id.org/itsdata/regulation/> .

<https://w3id.org/itsdata/regulation/> rdf:type owl:Ontology ;
                                        owl:versionIRI <https://w3id.org/itsdata/regulation/0.0.2> ;
                                        owl:imports <http://www.w3.org/2002/07/owl> ,
                                                    <http://www.w3.org/2003/11/swrl> ,
                                                    <http://www.w3.org/2003/11/swrlb> ,
                                                    <http://www.w3.org/2006/time> ,
                                                    cdm1: ,
                                                    its-core: ,
                                                    its-location: ,
                                                    its-time: ,
                                                    <https://www.opengis.net/ont/geosparql> ;
                                        dc:title "Ontology for Traffic Regulations" ;
                                        terms:description "This ontology defines concepts related to traffic regulations using concepts specified in ISO/IEC 5087-1 and ISO/IEC-5087-2." .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
terms:description rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2001/XMLSchema#pattern
xsd:pattern rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#gDay
xsd:gDay rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#gMonth
xsd:gMonth rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#time
xsd:time rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/citydata/part3/ITSObjectProperty
cdm3:ITSObjectProperty rdf:type owl:ObjectProperty .


###  https://w3id.org/itsdata/regulation/RegulationObjectProperty
:RegulationObjectProperty rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf cdm3:ITSObjectProperty .


###  https://w3id.org/itsdata/regulation/externalReferences
:externalReferences rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :RegulationObjectProperty .


###  https://w3id.org/itsdata/regulation/implementedLocation
:implementedLocation rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :RegulationObjectProperty .


###  https://w3id.org/itsdata/regulation/implementedValidity
:implementedValidity rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :RegulationObjectProperty .


###  https://w3id.org/itsdata/regulation/issuingAuthority
:issuingAuthority rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :RegulationObjectProperty ;
                  dc:description "The entity that issued the instance of the containing class" .


###  https://w3id.org/itsdata/regulation/legalBasis
:legalBasis rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :RegulationObjectProperty ;
            terms:description "formal authority within the law (e.g., statute, ordinance, administrative rule, constitutional provision) that empowers an entity to create, adopt, or enforce a regulation" .


###  https://w3id.org/itsdata/regulation/reasonCode
:reasonCode rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :RegulationObjectProperty ;
            dc:description "A reason justifying the existence of the instance of the class" .


###  https://w3id.org/itsdata/regulation/status
:status rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :RegulationObjectProperty ;
        dc:description "The status of the instance of the containing class" .


###  https://w3id.org/itsdata/regulation/trafficRegulation
:trafficRegulation rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :RegulationObjectProperty .


###  https://w3id.org/itsdata/regulation/validityByOrder
:validityByOrder rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :RegulationObjectProperty .


###  https://w3id.org/itsdata/regulation/validityTimeSpecification
:validityTimeSpecification rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf :RegulationObjectProperty .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/citydata/part1/hasDescription
cdm1:hasDescription rdf:type owl:DatatypeProperty .


###  https://w3id.org/citydata/part1/hasIdentifier
cdm1:hasIdentifier rdf:type owl:DatatypeProperty .


###  https://w3id.org/citydata/part1/hasName
cdm1:hasName rdf:type owl:DatatypeProperty .


###  https://w3id.org/citydata/part3/ITSDataProperty
cdm3:ITSDataProperty rdf:type owl:DatatypeProperty .


###  https://w3id.org/itsdata/regulation/TroDataProperty
:TroDataProperty rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf cdm3:ITSDataProperty .


###  https://w3id.org/itsdata/regulation/date
:date rdf:type owl:DatatypeProperty .


###  https://w3id.org/itsdata/regulation/index
:index rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf cdm3:ITSDataProperty .


###  https://w3id.org/itsdata/regulation/predefinedItineraryReference
:predefinedItineraryReference rdf:type owl:DatatypeProperty ;
                              rdfs:subPropertyOf :TroDataProperty .


###  https://w3id.org/itsdata/regulation/predefinedLocationGroupReference
:predefinedLocationGroupReference rdf:type owl:DatatypeProperty ;
                                  rdfs:subPropertyOf :TroDataProperty .


###  https://w3id.org/itsdata/regulation/version
:version rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf :TroDataProperty .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/citydata/part2/Code
cdm2:Code rdf:type owl:Class .


###  https://w3id.org/citydata/part3/ITSPattern
cdm3:ITSPattern rdf:type owl:Class .


###  https://w3id.org/citydata/part3/ITSThing
cdm3:ITSThing rdf:type owl:Class .


###  https://w3id.org/itsdata/regulation/LegalBasis
:LegalBasis rdf:type owl:Class ;
            rdfs:subClassOf :TroThing ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty cdm1:hasName ;
                              owl:allValuesFrom xsd:string
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :date ;
                              owl:allValuesFrom xsd:date
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :version ;
                              owl:allValuesFrom xsd:string
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty cdm1:hasName ;
                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onDataRange xsd:string
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :date ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onDataRange xsd:date
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :version ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onDataRange xsd:string
                            ] ;
            terms:description "A legal basis provides references to the legal documents that authorize an entity to issue the types of regulations covered by a traffic regulation order." ;
            xsd:pattern "TroPattern" .


###  https://w3id.org/itsdata/regulation/RuleMaker
:RuleMaker rdf:type owl:Class ;
           rdfs:subClassOf :TroThing ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :legalBasis ;
                             owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :LegalBasis
                           ] ;
           terms:description "A rule maker is an entity that has the responsibility for creating and maintaining rules of the road or regulations for a geographic and operational scope as defined by the parent jurisdictional entity." ;
           xsd:pattern "TroPattern" .


###  https://w3id.org/itsdata/regulation/TrafficRegulation
:TrafficRegulation rdf:type owl:Class ;
                   rdfs:subClassOf :TroThing ;
                   terms:description "A traffic regulation is a rule having the force of law that is established by a regulator through a traffic regulation order." ;
                   xsd:pattern "TroPattern" .


###  https://w3id.org/itsdata/regulation/TrafficRegulationOrder
:TrafficRegulationOrder rdf:type owl:Class ;
                        rdfs:subClassOf :TroThing ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :implementedValidity ;
                                          owl:allValuesFrom its-time:Validity
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :issuingAuthority ;
                                          owl:allValuesFrom :RuleMaker
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :legalBasis ;
                                          owl:allValuesFrom :LegalBasis
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :reasonCode ;
                                          owl:allValuesFrom cdm2:Code
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :status ;
                                          owl:allValuesFrom cdm2:Code
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :trafficRegulation ;
                                          owl:allValuesFrom :TrafficRegulation
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :validityByOrder ;
                                          owl:allValuesFrom its-time:Validity
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :trafficRegulation ;
                                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onClass :TrafficRegulation
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :issuingAuthority ;
                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onClass :RuleMaker
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :status ;
                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onClass cdm2:Code
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :implementedValidity ;
                                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onClass its-time:Validity
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :legalBasis ;
                                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onClass :LegalBasis
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :validityByOrder ;
                                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onClass its-time:Validity
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty cdm1:hasDescription ;
                                          owl:allValuesFrom xsd:string
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty cdm1:hasIdentifier ;
                                          owl:allValuesFrom xsd:string
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty cdm1:hasIdentifier ;
                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onDataRange xsd:string
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty cdm1:hasDescription ;
                                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onDataRange xsd:string
                                        ] ;
                        terms:description "A TrafficRegulation Order is a legally recognized document that specifies one or more traffic regulations." ;
                        xsd:pattern "TroPattern" .


###  https://w3id.org/itsdata/regulation/TroPattern
:TroPattern rdf:type owl:Class ;
            rdfs:subClassOf cdm3:ITSPattern .


###  https://w3id.org/itsdata/regulation/TroThing
:TroThing rdf:type owl:Class ;
          rdfs:subClassOf cdm3:ITSThing ;
          xsd:pattern "TroPattern" .


###  https://w3id.org/itsdata/time/Validity
its-time:Validity rdf:type owl:Class .


