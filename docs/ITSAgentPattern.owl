<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/itsdata/agent/v1/"
     xml:base="https://w3id.org/itsdata/agent/v1/"
     xmlns:cc="http://creativecommons.org/ns#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:i72="https://w3id.org/citydata/21972/v1/"
     xmlns:cdm1="https://w3id.org/citydata/part1/v1/"
     xmlns:its-core="https://w3id.org/itsdata/core/v1/">
    <owl:Ontology rdf:about="https://w3id.org/itsdata/agent/v1/">
    	<!-- Identity -->
    	<dcterms:title>ITS Agent Ontology</dcterms:title>
    	<skos:definition>This ontology defines concepts related to ITS agents.</skos:definition>
    	<vann:preferredNamespaceUri>https://w3id.org/itsdata/agent/v1/</vann:preferredNamespaceUri>
    	<vann:preferredNamespacePrefix>its-agent</vann:preferredNamespacePrefix>
        <cdm1:mainModule>true</cdm1:mainModule>
        <its-core:draft>true</its-core:draft>
    		
    	<!-- Provenance -->
    	<dcterms:creator>Kenneth Vaughn</dcterms:creator>
        <dcterms:created>Draft</dcterms:created>
        <!-- Prior release -->
        <!-- This release -->
		<dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-03</dcterms:modified>
        <owl:versionInfo>0.0.2</owl:versionInfo>
        <owl:versionIRI rdf:resource="https://w3id.org/itsdata/agent/v1/r0.2"/>
        <!-- TODO: I need to make sure that the above IRIs will work, in particular, the w3id redirect needs to be able to recognize that the r#.# extension is a release and not a class or property. -->
        
        <!-- License -->
        <dcterms:license>http://creativecommons.org/licenses/by/4.0/</dcterms:license>
        
        <!-- Imports -->
        <owl:imports rdf:resource="https://w3id.org/citydata/part1/v1/Agent.owl"/>
    </owl:Ontology>

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- https://w3id.org/itsdata/agent/v1/ITSAgentObjectProperty -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/agent/v1/ITSAgentObjectProperty">
    		<skos:definition>An object property to organize all object properties defined in the ITS Agent Ontology.</skos:definition>
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/core/v1/ITSObjectProperty"/>
    </owl:ObjectProperty>
    
    <!-- https://w3id.org/itsdata/agent/v1/playsRole -->
    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/agent/v1/playsRole">
        <skos:definition>Indicates the role that an agent performs.</skos:definition>
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/agent/v1/ITSAgentObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/itsdata/agent/v1/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/agent/v1/Role"/>
    </owl:ObjectProperty>


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- https://w3id.org/itsdata/agent/v1/ITSAgentThing -->

    <owl:Class rdf:about="https://w3id.org/itsdata/agent/v1/ITSAgentThing">
        <skos:definition>Added for organizational purposes to identify classes defined in the Agent part of the ITS Ontology.</skos:definition>
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/core/v1/ITSThing"/>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/agent/v1/Agent -->

    <owl:Class rdf:about="https://w3id.org/itsdata/agent/v1/Agent">
        <skos:definition>A person, organization, group, or software agent that performs a role. The role may add additional properties to the agent.</skos:definition>
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/agent/v1/ITSAgentThing"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/citydata/part1/v1/Agent"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/itsdata/agent/v1/playsRole"/>
                <owl:allValuesFrom rdf:resource="https://w3id.org/itsdata/agent/v1/Role"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    

    <!-- https://w3id.org/itsdata/agent/v1/Role -->

    <owl:Class rdf:about="https://w3id.org/itsdata/agent/v1/Role">
        <skos:definition>A role that an agent can perform. The role may add additional properties to the agent.</skos:definition>
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/agent/v1/ITSAgentThing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/citydata/part1/v1/hasName"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    
</rdf:RDF>